# ─── Database ─────────────────────────────────────────────────────
# Used by docker-compose postgres service (and all services via DATABASE_URL)
# No need to change this when using docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wreckify

# ─── NestJS API ───────────────────────────────────────────────────
JWT_SECRET=change_me_at_least_32_characters_long
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_at_least_32_chars
JWT_REFRESH_EXPIRES_IN=7d

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Must match INTERNAL_API_KEY in AI service
AI_SERVICE_INTERNAL_KEY=wreckify_internal_key_change_me

# 32-char key for AES-256 encryption of BYOK API keys
ENCRYPTION_KEY=wreckify_aes_key_32_chars_padded

# ─── AI Service ───────────────────────────────────────────────────
DEFAULT_GEMINI_API_KEY=

# ─── Scraper ──────────────────────────────────────────────────────
SCRAPER_INTERVAL_HOURS=12

# ─── Frontend ─────────────────────────────────────────────────────
# Must be the public-facing URL of the API (used at Next.js build time)
NEXT_PUBLIC_API_URL=http://localhost:3001
